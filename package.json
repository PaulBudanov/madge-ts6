{
  "name": "madge-ts6",
  "version": "8.0.1",
  "author": "Paul Budanov",
  "contributors": [
    "Patrik Henningsson <patrik.henningsson@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PaulBudanov/madge-ts6.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "bugs": {
    "url": "https://github.com/PaulBudanov/madge-ts6/issues"
  },
  "homepage": "https://github.com/PaulBudanov/madge-ts6#readme",
  "license": "MIT",
  "description": "Fork of madge with TypeScript 6 peer dependency support.",
  "keywords": [
    "ES6",
    "ES7",
    "AMD",
    "RequireJS",
    "require",
    "module",
    "circular",
    "dependency",
    "dependencies",
    "graphviz",
    "graph"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./lib/api.js",
  "types": "./lib/api.d.ts",
  "exports": {
    ".": {
      "types": "./lib/api.d.ts",
      "require": "./lib/api.js",
      "default": "./lib/api.js"
    },
    "./api": {
      "types": "./lib/api.d.ts",
      "require": "./lib/api.js",
      "default": "./lib/api.js"
    },
    "./lib/api": {
      "types": "./lib/api.d.ts",
      "require": "./lib/api.js",
      "default": "./lib/api.js"
    },
    "./lib/api.js": {
      "types": "./lib/api.d.ts",
      "require": "./lib/api.js",
      "default": "./lib/api.js"
    },
    "./lib/cyclic": {
      "types": "./lib/cyclic.d.ts",
      "require": "./lib/cyclic.js",
      "default": "./lib/cyclic.js"
    },
    "./lib/cyclic.js": {
      "types": "./lib/cyclic.d.ts",
      "require": "./lib/cyclic.js",
      "default": "./lib/cyclic.js"
    },
    "./lib/graph": {
      "types": "./lib/graph.d.ts",
      "require": "./lib/graph.js",
      "default": "./lib/graph.js"
    },
    "./lib/graph.js": {
      "types": "./lib/graph.d.ts",
      "require": "./lib/graph.js",
      "default": "./lib/graph.js"
    },
    "./lib/log": {
      "types": "./lib/log.d.ts",
      "require": "./lib/log.js",
      "default": "./lib/log.js"
    },
    "./lib/log.js": {
      "types": "./lib/log.d.ts",
      "require": "./lib/log.js",
      "default": "./lib/log.js"
    },
    "./lib/output": {
      "types": "./lib/output.d.ts",
      "require": "./lib/output.js",
      "default": "./lib/output.js"
    },
    "./lib/output.js": {
      "types": "./lib/output.d.ts",
      "require": "./lib/output.js",
      "default": "./lib/output.js"
    },
    "./lib/tree": {
      "types": "./lib/tree.d.ts",
      "require": "./lib/tree.js",
      "default": "./lib/tree.js"
    },
    "./lib/tree.js": {
      "types": "./lib/tree.d.ts",
      "require": "./lib/tree.js",
      "default": "./lib/tree.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "lib",
    "src"
  ],
  "bin": {
    "madge": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && npm run lint && npm run mocha",
    "mocha": "mocha test/*.js",
    "watch": "mocha --watch --growl test/*.js",
    "lint": "eslint bin/cli.js test/*.js",
    "predebug": "npm run build",
    "debug": "node bin/cli.js --debug bin lib",
    "pregenerate": "npm run build",
    "generate": "npm run generate:small && npm run generate:madge",
    "generate:small": "bin/cli.js --image /tmp/simple.svg test/cjs/circular/a.js",
    "generate:madge": "bin/cli.js --image /tmp/madge.svg bin lib",
    "test:output": "./test/output.sh",
    "prepack": "npm run build",
    "release": "semantic-release"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^7.2.0",
    "commondir": "^1.0.1",
    "debug": "^4.3.4",
    "dependency-tree": "^11.0.0",
    "ora": "^5.4.1",
    "pluralize": "^8.0.0",
    "pretty-ms": "^7.0.1",
    "rc": "^1.2.8",
    "stream-to-array": "^2.3.0",
    "ts-graphviz": "^2.1.2",
    "walkdir": "^0.4.1"
  },
  "peerDependencies": {
    "typescript": "^5.4.4 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aptoma/eslint-config": "^7.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^7.29.0",
    "mocha": "^9.0.1",
    "mz": "^2.7.0",
    "should": "^13.2.3",
    "typescript": "^6.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "semantic-release": "^25.0.2"
  }
}
